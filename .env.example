# Copy to .env.local and fill in. Never commit real secrets.

# Neon Postgres — pooled connection string (postgresql://...)
DATABASE_URL=

# Auth.js v5 session secret — generate with: npx auth secret
AUTH_SECRET=

# Google Gemini (Vercel AI SDK) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Upstash Redis — rate limiting (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
